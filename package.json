{
  "name": "velib-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma db push && prisma generate && next dev",
    "db:push": "prisma db push && prisma generate",
    "db:fix": "node scripts/fix-password-hash.cjs && prisma db push && prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "docker:build": "docker compose build --no-cache app",
    "docker:up": "docker compose up -d --build",
    "docker:refresh": "docker compose down && docker compose build --no-cache app && docker compose up -d"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
