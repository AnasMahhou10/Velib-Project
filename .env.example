# Copier vers .env uniquement pour npm run dev (sans Docker) :
#   copy .env.example .env

# Développement local (npm run dev) — Postgres sur localhost, app sur http://localhost:3000
DATABASE_URL=postgresql://velib:velib@localhost:5432/velib_db

# JWT (min. 16 caractères) — changer en production
JWT_SECRET=change-me-use-a-long-random-secret-in-production

# Docker Compose : pas besoin de .env pour démarrer.
#   docker compose up --build  →  http://localhost:3000
# Variables injectées par docker-compose.yml (DATABASE_URL, JWT_SECRET).
# Hostname "db" ne fonctionne pas hors conteneur Docker.
