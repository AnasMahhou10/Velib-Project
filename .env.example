# Copier vers .env : copy .env.example .env

# Développement local (npm run dev) — Postgres sur localhost
DATABASE_URL=postgresql://velib:velib@localhost:5432/velib_db

# JWT (min. 16 caractères) — changer en production
JWT_SECRET=change-me-use-a-long-random-secret-in-production

# Docker Compose uniquement (hostname "db" ne marche PAS hors Docker)
# DATABASE_URL=postgresql://velib:velib@db:5432/velib_db
